# Stay22 Direct Travel API key. Leave blank to run the whole game in
# fallback/simulated mode (live:false) — this is the default demo path and
# requires no key at all.
STAY22_API_KEY=

# Stay22 campaign/aid used to tag tracked booking links and to filter the
# transactions report. Defaults to 'concierge-royal-york' if unset.
STAY22_CAMPAIGN_ID=concierge-royal-york

# Presage/SmartSpectra API key for live biometric signals (talking/breathing
# detection). Leave blank to use the local getUserMedia-based fallback engine.
PRESAGE_API_KEY=

# Optional: port the local Stay22 API server listens on (server/index.mjs).
# vite.config.js proxies /api to this port. Defaults to 8787.
STAY22_SERVER_PORT=8787
